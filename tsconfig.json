{
    "compilerOptions": {
        "lib": ["ES2023", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022",
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "tests/**/*.ts", "tsup.config.ts"]
}
